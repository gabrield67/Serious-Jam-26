; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="'NADO"
config/tags=PackedStringArray("jam")
run/main_scene="uid://bm6ip6oknw3wn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

PhantomCameraManager="*res://addons/phantom_camera/scripts/managers/phantom_camera_manager.gd"

[display]

window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
mouse_cursor/custom_image="res://assets/UI/cursor/crosshair002.png"
mouse_cursor/custom_image_hotspot=Vector2(32, 32)

[editor]

movie_writer/movie_file="C:/Users/tmntf/Documents/Godot/Projects/Serious-Jam-26/Screens/HomeScreenMovie.ogv"

[editor_plugins]

enabled=PackedStringArray("res://addons/blender_godot_pipeline/plugin.cfg", "res://addons/phantom_camera/plugin.cfg", "res://addons/road-generator/plugin.cfg", "res://addons/terrain_3d/plugin.cfg", "res://addons/voronoishatter/plugin.cfg")

